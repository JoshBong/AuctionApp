@model List<AuctionApp.Data.AuctionItem>
@{
    ViewData["Title"] = "Auction Room";
}

<div class="site-header" style="background: transparent; border: none; margin-bottom: 1.5rem;">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="section-title">&#x1F3AA; Auction Room</h1>
            <p class="section-subtitle">Hey <strong>@ViewBag.Username</strong>, place your bids below. Prices update live!</p>
        </div>
        <form action="/Home/Logout" method="post">
            <button type="submit" class="btn btn-logout">Sign Out</button>
        </form>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert-bid-success mb-3">
        @TempData["Message"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-bid-error mb-3">
        @TempData["Error"]
    </div>
}

@if (Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="auction-card" data-item-id="@item.ItemId">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <div class="item-name">@item.ItemName</div>
                    <div class="item-desc">@item.Description</div>
                </div>
                <div class="col-md-3 text-center py-2">
                    <div class="price-label">Current Price</div>
                    <div class="current-price">$@item.CurrentPrice</div>
                </div>
                <div class="col-md-5">
                    <form action="/Bidder/PlaceBid" method="post" class="bid-form">
                        <input type="hidden" name="itemId" value="@item.ItemId" />
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" name="amount" class="form-control bid-input"
                                   step="1" min="@(item.CurrentPrice + 1m)"
                                   placeholder="@(item.CurrentPrice + 1m)+" required />
                            <button type="submit" class="btn btn-bid">Bid</button>
                        </div>
                        <div class="min-bid-hint">Min bid: $@(item.CurrentPrice + 1m)</div>
                    </form>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="empty-state">
        <h4>No items up for auction yet</h4>
        <p>Check back soon - someone might put something ridiculous up for grabs.</p>
    </div>
}

<div class="footer-area">
    <p>Josh's Auction</p>
</div>
