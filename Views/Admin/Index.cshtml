@model List<AuctionApp.Data.Bid>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="site-header" style="background: transparent; border: none; margin-bottom: 1.5rem;">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="section-title">&#x1F4CB; Bid Monitor</h1>
            <p class="section-subtitle">Live feed of all auction activity &middot; Logged in as <strong>@ViewBag.Username</strong></p>
        </div>
        <form action="/Home/Logout" method="post">
            <button type="submit" class="btn btn-logout">Sign Out</button>
        </form>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert-bid-success mb-3">
        @TempData["Message"]
    </div>
}

@if (Model.Any())
{
    <div class="card" style="overflow: hidden;">
        <div class="table-responsive mb-0">
            <table class="table bids-table mb-0" id="bids-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Item</th>
                        <th>Bidder</th>
                        <th>Amount</th>
                        <th>Time</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bid in Model.OrderByDescending(b => b.BidTime))
                    {
                        <tr data-bid-id="@bid.BidID">
                            <td style="color: var(--text-muted);">@bid.BidID</td>
                            <td><strong>@bid.ItemName</strong></td>
                            <td>@bid.Username</td>
                            <td><strong style="color: var(--success);">$@bid.Amount</strong></td>
                            <td style="color: var(--text-muted);">@bid.BidTime.ToString("MMM d, h:mm tt")</td>
                            <td>
                                <span class="badge-role @(bid.Role == "Admin" ? "badge-admin" : "badge-bidder")">
                                    @bid.Role
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <h4>No bids yet</h4>
        <p>Once people start bidding, activity will show up here in real-time.</p>
    </div>
}

<div class="footer-area">
    <p>Josh's Auction Admin</p>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof connection !== 'undefined' && connection) {
                connection.on("BidUpdated", function (itemId, newPrice, bidderName) {
                    addNewBidRow(itemId, newPrice, bidderName);
                });
            }
        });

        function addNewBidRow(itemId, amount, bidderName) {
            const table = document.querySelector('#bids-table tbody');
            if (!table) return;

            const now = new Date();
            const timeStr = now.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
                          + ', ' + now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

            const row = document.createElement('tr');
            row.style.background = 'var(--success-soft)';
            row.innerHTML = `
                <td style="color: var(--text-muted);">New</td>
                <td><strong>Item ${itemId}</strong></td>
                <td>${bidderName}</td>
                <td><strong style="color: var(--success);">$${amount}</strong></td>
                <td style="color: var(--text-muted);">${timeStr}</td>
                <td><span class="badge-role badge-bidder">Bidder</span></td>
            `;

            table.insertBefore(row, table.firstChild);
            setTimeout(() => { row.style.background = ''; }, 3000);
        }
    </script>
}
